[
  {
    "stepTitle": "组网设置",
    "items": [
      {
        "type": "text",
        "field": "et_network_name",
        "label": "网络名称",
        "initValue": "admin",
        "rules": [
          {
            "required": true,
            "message": "请输入网络名称"
          },
          {
            "pattern": "^[a-zA-Z0-9_]+$",
            "message": "网络名称只能包含字母、数字和下划线"
          }
        ]
      },
      {
        "type": "password",
        "field": "et_network_secret",
        "label": "网络密码",
        "rules": [
          {
            "required": true,
            "message": "请输入网络密码"
          },
          {
            "min": 3,
            "message": "密码长度不能少于3位"
          }
        ]
      },
      {
        "type": "tips",
        "helpText": "修改网络名称或密码，需要所有组网节点修改一致，否则不能组网"
      },
      {
        "type": "text",
        "field": "et_version",
        "label": "EasyTier核心版本",
        "initValue": "2.5.0",
        "rules": [
          {
            "required": true,
            "message": "EasyTier核心版本"
          }
        ]
      },
      {
        "type": "tips",
        "helpText": "<a href=\"https://github.com/EasyTier/EasyTier/releases\">EasyTier所有版本</a>"
      },
      {
        "type": "text",
        "field": "github_proxy_url",
        "label": "GitHub加速地址",
        "initValue": "https://ghfast.top"
      }
    ]
  }
]
